cff-version: 1.2.0
title: "CyberSecQwen-4B: A Compact CTI Specialist Fine-Tuned from Qwen3-4B-Instruct-2507 on AMD MI300X"
type: software
authors:
  - family-names: Mulia
    given-names: Samuel
    alias: athena129
